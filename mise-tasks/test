#!/usr/bin/env bash
#MISE description="Run plugin tests - install and execute tool"
set -euo pipefail

mise plugin link --force pgbouncer-exporter .
mise cache clear
mise install pgbouncer-exporter@0.12.0

# Capture and display the output while also verifying it
output=$(mise exec "pgbouncer-exporter@0.12.0" -- "pgbouncer_exporter" --version 2>&1)
echo "pgbouncer-exporter output: ${output}"

if echo "${output}" | grep -q '0.12.0'; then
  echo "✓ Tests passed"
else
  echo "✗ Test failed: expected version pgbouncer-exporter@0.12.0"
  exit 1
fi
